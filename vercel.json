{
  "rewrites": [
    {
      "source": "/api/:path*",
      "destination": "https://ai-daily-backend.onrender.com/api/:path*"
    },
    {
      "source": "/report/:id",
      "destination": "/index.html"
    },
    {
      "source": "/history",
      "destination": "/index.html"
    },
    {
      "source": "/chat",
      "destination": "/index.html"
    },
    {
      "source": "/subscribe",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/api/:path*",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "Access-Control-Allow-Methods",
          "value": "GET, POST, PUT, DELETE, OPTIONS"
        },
        {
          "key": "Access-Control-Allow-Headers",
          "value": "Content-Type"
        }
      ]
    }
  ]
}
